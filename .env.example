# ─── LLM — Claude Haiku 4.5 ($1 / $5 per 1M tokens) ────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── News Collection ─────────────────────────────────────────────────────────
# DuckDuckGo + RSS : GRATUITS, aucune clé requise
# Tavily : OPTIONNEL — 1 000 req/mois gratuits (plan Starter)
# Laisser vide pour utiliser uniquement les sources gratuites.
TAVILY_API_KEY=

# ─── Email — Resend (3 000 emails/mois GRATUITS) ─────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=newsletter@yourdomain.com
FROM_NAME=HNWI Prospect Intelligence

# ─── Database — Supabase (cloud PostgreSQL, GRATUIT jusqu'à 500 MB) ──────────
# Créer un projet sur https://supabase.com → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_public_key_here

# TinyDB — fichier local pour prospects + logs (machine-local, éphémère)
DB_PATH=data/db.json

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
NEWSLETTER_HOUR=7             # Heure UTC d'envoi quotidien (7 = 07:00 UTC)
MAX_PROSPECTS=5               # Nombre de prospects dans la newsletter
MAX_DDG_PER_QUERY=5           # Résultats DuckDuckGo par requête
MAX_TAVILY_PER_QUERY=3        # Résultats Tavily par requête (quota limité)
